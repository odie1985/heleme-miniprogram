.field-label {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
  color: #374151;
}

.type-row {
  display: flex;
  gap: 14rpx;
}

.type-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
}

.type-chip-active {
  background: #111827;
  color: #fff;
}

.input-like {
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f9fafb;
}

.textarea-like {
  width: 100%;
  min-height: 180rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f9fafb;
  box-sizing: border-box;
}

.submit {
  margin-top: 24rpx;
}
