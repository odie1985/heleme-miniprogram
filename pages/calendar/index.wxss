.week-head {
  margin-bottom: 12rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  color: #6b7280;
  font-size: 24rpx;
  text-align: center;
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f3f4f6;
  color: #374151;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.month-title {
  color: #111827;
  text-decoration: underline;
  text-decoration-style: dashed;
  text-underline-offset: 6rpx;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.day-item {
  position: relative;
  height: 86rpx;
  border-radius: 14rpx;
  background: #f9fafb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-placeholder {
  background: transparent;
}

.day-item.today {
  border: 2rpx solid #2563eb;
}

.day-item.active {
  background: #111827;
  color: #fff;
}

.day-item.today.active {
  border-color: #60a5fa;
}

.day-dots {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.dot-drink {
  background: #f59e0b;
}

.dot-fitness {
  background: #2563eb;
}

.day-item.active .dot-drink {
  background: #fcd34d;
}

.day-item.active .dot-fitness {
  background: #93c5fd;
}

.log-list {
  margin-top: 22rpx;
}

.log-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.log-content {
  flex: 1;
}

.log-amount {
  color: #6b7280;
  font-size: 24rpx;
}

.log-arrow {
  color: #9ca3af;
  font-size: 28rpx;
}

.log-location {
  color: #6b7280;
  font-size: 22rpx;
}

.fab-add {
  position: fixed;
  right: 26rpx;
  bottom: 120rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #111827;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(17, 24, 39, 0.22);
  z-index: 40;
  padding: 0;
}

.fab-plus {
  font-size: 56rpx;
  line-height: 1;
  transform: translateY(-2rpx);
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.35);
  z-index: 50;
}

.panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 60;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 14rpx 30rpx rgba(17, 24, 39, 0.18);
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
}

.type-row {
  margin-top: 16rpx;
  display: flex;
  gap: 14rpx;
}

.type-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
}

.type-chip-active {
  background: #111827;
  color: #fff;
}

.field-label {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  color: #374151;
}

.option-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 24rpx;
}

.option-chip-active {
  background: #111827;
  color: #fff;
}

.location-row {
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f9fafb;
}

.location-text {
  color: #374151;
  font-size: 24rpx;
  word-break: break-all;
}

.location-actions {
  margin-top: 10rpx;
  display: flex;
  gap: 10rpx;
}

.location-btn {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #fff;
  font-size: 22rpx;
}

.location-btn.secondary {
  background: #e5e7eb;
  color: #374151;
}

.input-like {
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f9fafb;
}

.textarea-like {
  width: 100%;
  min-height: 140rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f9fafb;
  box-sizing: border-box;
}

.panel-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
}
