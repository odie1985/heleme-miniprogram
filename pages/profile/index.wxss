.profile-hero {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  background: #f3f3f3;
  padding: 24rpx 24rpx;
  margin: 0 0 20rpx;
}

.avatar-slot {
  width: 30%;
  max-width: 170rpx;
  min-width: 132rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.avatar-btn {
  width: auto;
  height: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 18rpx;
  overflow: hidden;
  border: none;
  background: transparent;
  line-height: 0;
  max-width: 100%;
  padding: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar-img,
.avatar-fallback {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
}

.avatar-fallback {
  background: #111827;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 40rpx;
}

.hero-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  min-width: 0;
}

.profile-name {
  max-width: 100%;
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #202124;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sleep-z {
  font-size: 34rpx;
  color: #2563eb;
  font-weight: 700;
  line-height: 1;
}

.wxid-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  color: #7c7d80;
  min-width: 0;
}

.wxid-value {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-pills {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: nowrap;
  min-width: 0;
}

.hero-pill {
  min-height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid #dadce0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #6f7175;
  font-size: 26rpx;
  line-height: 1.2;
  background: #f7f7f7;
  white-space: nowrap;
  box-sizing: border-box;
}

.friend-pill {
  position: relative;
  padding-right: 18rpx;
  min-width: 0;
}

.mini-avatar {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #8aa4c7;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
}

.red-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff4d4f;
  margin-left: 6rpx;
}

.hero-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
}

.qr-entry {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 6rpx;
  border: 2rpx solid #6b7fa8;
  position: relative;
  background: transparent;
}

.qr-corner {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border: 2rpx solid #6b7fa8;
}

.tl {
  left: 4rpx;
  top: 4rpx;
  border-right: none;
  border-bottom: none;
}

.tr {
  right: 4rpx;
  top: 4rpx;
  border-left: none;
  border-bottom: none;
}

.bl {
  left: 4rpx;
  bottom: 4rpx;
  border-right: none;
  border-top: none;
}

.qr-dot {
  position: absolute;
  right: 5rpx;
  bottom: 5rpx;
  width: 5rpx;
  height: 5rpx;
  background: #6b7fa8;
}

.arrow {
  color: #b1b3b8;
  font-size: 42rpx;
  line-height: 1;
}

.friend-list {
  margin-top: 18rpx;
}

.entry-btn {
  width: 100%;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border-radius: 14rpx;
  text-align: center;
}

.friend-scan-btn {
  margin-top: 16rpx;
}

.friend-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.phone-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.phone-btn {
  min-width: 196rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: #111827;
  color: #fff;
  font-size: 22rpx;
}

.phone-btn::after {
  border: none;
}

.stat-month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f3f4f6;
  color: #374151;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.month-title {
  color: #111827;
  text-decoration: underline;
  text-decoration-style: dashed;
  text-underline-offset: 6rpx;
}

.stat-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.stat-item {
  border-radius: 16rpx;
  padding: 18rpx;
}

.stat-drink {
  background: #fff7e6;
}

.stat-fitness {
  background: #eaf2ff;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.rate-line {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  color: #6b7280;
  font-size: 24rpx;
}

.progress-wrap {
  margin-top: 12rpx;
  display: flex;
  width: 100%;
  height: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.progress {
  height: 100%;
}

.progress-drink {
  background: #f59e0b;
}

.progress-fitness {
  background: #2563eb;
}

.pie-wrap {
  position: relative;
  margin-top: 12rpx;
  display: flex;
  justify-content: center;
}

.drink-pie-canvas {
  width: 260rpx;
  height: 260rpx;
}

.pie-empty {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
}

.pie-legend {
  margin-top: 10rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
  color: #4b5563;
  font-size: 24rpx;
}

.legend-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.legend-right {
  color: #6b7280;
}

.pie-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.pie-panel {
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 14rpx;
}

.pie-title {
  font-size: 24rpx;
  color: #374151;
  font-weight: 600;
}

.pie-panel-main {
  margin-top: 6rpx;
}

.pie-wrap.compact {
  margin-top: 4rpx;
}

.drink-pie-canvas.compact {
  width: 180rpx;
  height: 180rpx;
}

.pie-legend.compact {
  margin-top: 6rpx;
}

.legend-item.compact {
  padding: 4rpx 0;
  font-size: 20rpx;
}

.legend-left.compact {
  gap: 8rpx;
}
