page {
  background: #f4f6f8;
}

.feed-cover {
  position: relative;
  height: 360rpx;
  padding: 38rpx 28rpx 30rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 14% 10%, rgba(255, 78, 197, 0.18), transparent 18%),
    radial-gradient(circle at 88% 18%, rgba(0, 220, 255, 0.16), transparent 20%),
    linear-gradient(180deg, rgba(16, 24, 38, 0.16), rgba(16, 24, 38, 0.42)),
    linear-gradient(135deg, #21163a 0%, #24324e 36%, #111827 100%);
  overflow: hidden;
}

.cover-pattern {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(120deg, transparent 0, transparent 44%, rgba(255, 255, 255, 0.05) 45%, transparent 46%, transparent 100%),
    linear-gradient(160deg, transparent 0, transparent 58%, rgba(255, 255, 255, 0.03) 59%, transparent 60%, transparent 100%);
}

.cover-streak {
  position: absolute;
  height: 2rpx;
  transform: rotate(-20deg);
  transform-origin: left center;
  opacity: 0.6;
}

.streak-a {
  top: 96rpx;
  left: -40rpx;
  width: 340rpx;
  background: linear-gradient(90deg, transparent, rgba(110, 232, 255, 0.82), transparent);
}

.streak-b {
  top: 146rpx;
  right: -30rpx;
  width: 280rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 99, 208, 0.78), transparent);
}

.streak-c {
  bottom: 76rpx;
  left: 84rpx;
  width: 400rpx;
  background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.62), transparent);
}

.cover-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(34rpx);
  opacity: 0.75;
}

.glow-pink {
  left: -20rpx;
  top: 150rpx;
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 78, 197, 0.2);
}

.glow-cyan {
  right: -10rpx;
  top: 72rpx;
  width: 170rpx;
  height: 170rpx;
  background: rgba(34, 211, 238, 0.18);
}

.cover-float {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: rgba(13, 18, 36, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12rpx);
}

.float-a {
  left: 26rpx;
  top: 126rpx;
  width: 76rpx;
  height: 76rpx;
  transform: rotate(-10deg);
  color: #ff7dd9;
  box-shadow: 0 0 20rpx rgba(255, 125, 217, 0.18);
}

.float-b {
  right: 48rpx;
  top: 70rpx;
  width: 86rpx;
  height: 86rpx;
  transform: rotate(9deg);
  color: #78e7ff;
  box-shadow: 0 0 20rpx rgba(120, 231, 255, 0.2);
}

.float-c {
  right: 124rpx;
  top: 184rpx;
  width: 70rpx;
  height: 70rpx;
  transform: rotate(-7deg);
  color: #8b5cf6;
  box-shadow: 0 0 20rpx rgba(139, 92, 246, 0.18);
}

.float-d {
  left: 138rpx;
  top: 66rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  transform: rotate(8deg);
  color: #ff9a58;
  box-shadow: 0 0 18rpx rgba(255, 154, 88, 0.16);
}

.mini-doodle {
  position: relative;
}

.doodle-bottle {
  width: 24rpx;
  height: 40rpx;
  border: 2rpx solid currentColor;
  border-radius: 8rpx 8rpx 10rpx 10rpx;
  box-sizing: border-box;
}

.doodle-bottle::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 7rpx;
  width: 8rpx;
  height: 10rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 4rpx 4rpx 0 0;
  box-sizing: border-box;
}

.doodle-bottle::after {
  content: '';
  position: absolute;
  left: 4rpx;
  top: 14rpx;
  width: 12rpx;
  height: 8rpx;
  border-radius: 999rpx;
  border: 2rpx solid currentColor;
  box-sizing: border-box;
}

.doodle-dumbbell {
  width: 34rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.doodle-dumbbell::before,
.doodle-dumbbell::after {
  content: '';
  position: absolute;
  top: -10rpx;
  width: 8rpx;
  height: 28rpx;
  border: 2rpx solid currentColor;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.doodle-dumbbell::before {
  left: -12rpx;
}

.doodle-dumbbell::after {
  right: -12rpx;
}

.doodle-chat {
  width: 30rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.doodle-chat::before {
  content: '';
  position: absolute;
  left: 6rpx;
  bottom: -7rpx;
  width: 10rpx;
  height: 10rpx;
  border-left: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
  transform: skew(-18deg);
}

.doodle-star {
  width: 20rpx;
  height: 20rpx;
}

.doodle-star::before,
.doodle-star::after {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 0;
  width: 2rpx;
  height: 20rpx;
  background: currentColor;
  border-radius: 999rpx;
}

.doodle-star::after {
  transform: rotate(90deg);
}

.feed-toolbar {
  margin-top: -16rpx;
  padding: 0 24rpx;
  position: relative;
  z-index: 2;
}

.filters {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.second-row {
  margin-top: 12rpx;
}

.chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #6b7280;
  font-size: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.chip-active {
  background: #111827;
  color: #fff;
}

.feed-list {
  padding: 18rpx 24rpx 34rpx;
}

.moment-item {
  display: flex;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.moment-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
}

.tone-blue {
  background: linear-gradient(135deg, #60a5fa, #2563eb);
}

.tone-pink {
  background: linear-gradient(135deg, #fb7185, #ec4899);
}

.tone-violet {
  background: linear-gradient(135deg, #a78bfa, #7c3aed);
}

.tone-amber {
  background: linear-gradient(135deg, #fbbf24, #f97316);
}

.tone-cyan {
  background: linear-gradient(135deg, #22d3ee, #0891b2);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.moment-main {
  flex: 1;
  min-width: 0;
}

.moment-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
}

.moment-author {
  color: #1f4e8c;
  font-size: 30rpx;
  font-weight: 600;
}

.moment-source {
  color: #9ca3af;
  font-size: 22rpx;
}

.moment-content {
  margin-top: 12rpx;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-word;
}

.moment-meta-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.type-pill,
.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  line-height: 1.3;
}

.type-drink {
  background: #fff7ed;
  color: #b45309;
}

.type-fitness {
  background: #eff6ff;
  color: #1d4ed8;
}

.meta-pill {
  background: #f3f4f6;
  color: #4b5563;
}

.location-pill {
  max-width: 100%;
  word-break: break-all;
}

.photo-grid {
  margin-top: 16rpx;
  display: grid;
  gap: 8rpx;
}

.grid-one {
  grid-template-columns: 1fr;
}

.grid-four {
  grid-template-columns: repeat(2, 1fr);
  max-width: 420rpx;
}

.grid-many {
  grid-template-columns: repeat(3, 1fr);
  max-width: 492rpx;
}

.feed-photo {
  width: 100%;
  height: 156rpx;
  border-radius: 12rpx;
  background: #e5e7eb;
}

.grid-one .feed-photo {
  max-width: 460rpx;
  height: 344rpx;
}

.moment-footer {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.moment-time {
  color: #9ca3af;
  font-size: 22rpx;
}

.moment-actions {
  min-width: 88rpx;
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.action-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #6b7280;
}

.moment-interaction {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f3f4f6;
}

.like-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #1f4e8c;
  font-size: 22rpx;
}

.like-icon {
  color: #ec4899;
  font-size: 20rpx;
}

.like-text {
  color: #1f4e8c;
}

.comment-list {
  margin-top: 10rpx;
  display: grid;
  gap: 8rpx;
}

.comment-item {
  font-size: 22rpx;
  line-height: 1.6;
  color: #374151;
  word-break: break-word;
}

.comment-name {
  color: #1f4e8c;
  font-weight: 600;
}

.comment-text {
  color: #374151;
}

.empty-wrap {
  margin: 28rpx 24rpx;
  padding: 48rpx 36rpx;
  border-radius: 28rpx;
  background: #fff;
  text-align: center;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.06);
}

.empty-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-sub {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.7;
}
